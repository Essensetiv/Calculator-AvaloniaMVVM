<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Calculator.ViewModels"   
        mc:Ignorable="d"
        x:Class="Calculator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Калькулятор"
        Width="420"
        Height="580"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,*,*,*,*,*"
          ColumnDefinitions="*,*,*,*"
          Margin="16">

        <!-- Экран -->
        <Border Grid.Row="0" 
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Background="#2D2D2D"
                CornerRadius="12"
                Margin="4,10,4,20"
                Padding="20,30">
            <TextBlock Text="{Binding ShownValue}"
                       FontSize="58"
                       FontWeight="Light"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#FFFFFF" />
        </Border>

        <!-- Кнопки -->

        <!-- Первая строка (серые) -->
        <Button Grid.Row="1" Grid.Column="0" Content="C"    
                Command="{Binding ClearCommand}" 
                Background="#3A3A3A" Foreground="#FF5252" FontSize="22" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="1" Grid.Column="1" Content="+/-" 
                Command="{Binding ToggleSignCommand}" 
                Background="#3A3A3A" Foreground="#FFFFFF" FontSize="22" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="1" Grid.Column="2" Content="%"    
                Command="{Binding PercentCommand}" 
                Background="#3A3A3A" Foreground="#FFFFFF" FontSize="22" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="1" Grid.Column="3" Content="÷"    
                Command="{Binding ExecuteOperationCommand}" 
                CommandParameter="/"
                Background="#FF9500" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <!-- Цифры + операции -->
        <Button Grid.Row="2" Grid.Column="0" Content="7" 
                Command="{Binding AddNumberCommand}" CommandParameter="7" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="2" Grid.Column="1" Content="8" 
                Command="{Binding AddNumberCommand}" CommandParameter="8" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="2" Grid.Column="2" Content="9" 
                Command="{Binding AddNumberCommand}" CommandParameter="9" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="2" Grid.Column="3" Content="×" 
                Command="{Binding ExecuteOperationCommand}" CommandParameter="*"
                Background="#FF9500" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="3" Grid.Column="0" Content="4" 
                Command="{Binding AddNumberCommand}" CommandParameter="4" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="3" Grid.Column="1" Content="5" 
                Command="{Binding AddNumberCommand}" CommandParameter="5" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="3" Grid.Column="2" Content="6" 
                Command="{Binding AddNumberCommand}" CommandParameter="6" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="3" Grid.Column="3" Content="-"  
                Command="{Binding ExecuteOperationCommand}" CommandParameter="-"
                Background="#FF9500" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2" />

        <Button Grid.Row="4" Grid.Column="0" Content="1" 
                Command="{Binding AddNumberCommand}" CommandParameter="1" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="4" Grid.Column="1" Content="2" 
                Command="{Binding AddNumberCommand}" CommandParameter="2" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="4" Grid.Column="2" Content="3" 
                Command="{Binding AddNumberCommand}" CommandParameter="3" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="4" Grid.Column="3" Content="+"  
                Command="{Binding ExecuteOperationCommand}" CommandParameter="+"
                Background="#FF9500" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <!-- Нижняя строка -->
        <Button Grid.Row="5" Grid.Column="0" Content="0" 
                Grid.ColumnSpan="2"
                Command="{Binding AddNumberCommand}" CommandParameter="0" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="5" Grid.Column="2" Content="." 
                Command="{Binding AddDecimalCommand}" 
                Background="#2D2D2D" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

        <Button Grid.Row="5" Grid.Column="3" Content="=" 
                Command="{Binding CalculateCommand}" 
                Background="#FF9500" Foreground="#FFFFFF" FontSize="26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="2"/>

    </Grid>
</Window>